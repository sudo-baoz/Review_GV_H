{
  "manifest_version": 3,
  "name": "Teacher Evaluation Filler",
  "version": "1.0",
  "description": "Auto-fill teacher evaluation forms using LLM",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
